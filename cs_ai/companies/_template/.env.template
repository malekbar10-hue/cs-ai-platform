# .env.template — Secret variables required by CS AI for this company.
#
# HOW TO USE:
#   1. Copy this file to your project root as .env
#   2. Replace COMPANY_NAME with your actual company identifier (e.g. ALPHA, BETA)
#   3. Fill in every value marked with  ← REQUIRED
#   4. Never commit .env to git (it is already in .gitignore)
#
# LOOKUP ORDER (example: company = "alpha", var = "ERP_TOKEN"):
#   The app tries ALPHA_ERP_TOKEN first, then falls back to ERP_TOKEN.
#   Using prefixed names lets you run multiple companies from one .env file.

# ── ERP connector ─────────────────────────────────────────────────────────────
COMPANY_NAME_ERP_TOKEN=          # ← REQUIRED if erp.type = erp_api / bearer
COMPANY_NAME_ERP_USER=           # ← REQUIRED if erp.type = erp_api / basic
COMPANY_NAME_ERP_PASS=           # ← REQUIRED if erp.type = erp_api / basic
COMPANY_NAME_ERP_API_KEY=        # ← REQUIRED if erp.type = erp_api / api_key

# ── OAuth2 (ERP or CRM) ────────────────────────────────────────────────────
COMPANY_NAME_OAUTH_TOKEN_URL=    # ← REQUIRED if using oauth2_client_credentials
COMPANY_NAME_OAUTH_CLIENT_ID=    # ← REQUIRED if using oauth2_client_credentials
COMPANY_NAME_OAUTH_SECRET=       # ← REQUIRED if using oauth2_client_credentials

# ── CRM connector ─────────────────────────────────────────────────────────────
COMPANY_NAME_CRM_API_KEY=        # ← REQUIRED if crm.type = crm_api

# ── Email (inbound + outbound) ────────────────────────────────────────────────
COMPANY_NAME_EMAIL_PASSWORD=     # ← REQUIRED if communication channels are enabled

# ── Notifications ─────────────────────────────────────────────────────────────
COMPANY_NAME_SUPERVISOR_EMAIL=   # ← REQUIRED for escalation email alerts
COMPANY_NAME_SLACK_WEBHOOK_URL=  # ← REQUIRED for Slack notifications

# ── OpenAI (shared — no company prefix) ───────────────────────────────────────
OPENAI_API_KEY=                  # ← REQUIRED for all AI features
